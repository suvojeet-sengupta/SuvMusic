<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include all data by default (databases, shared_prefs, files) -->
        <include domain="root" path="."/>
        
        <!-- Exclude non-essential/large items from cloud backup -->
        <!-- System automatically excludes context.getCacheDir(), so we don't need to specify it -->
        <exclude domain="file" path="thumbnails"/>
    </cloud-backup>
    <device-transfer>
        <!-- For device-to-device transfer, include everything for a complete migration -->
        <include domain="root" path="."/>
    </device-transfer>
</data-extraction-rules>