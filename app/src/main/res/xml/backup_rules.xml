<?xml version="1.0" encoding="utf-8"?><!--
   Sample backup rules file; uncomment and customize as necessary.
   See https://developer.android.com/guide/topics/data/autobackup
   for details.
   Note: This file is ignored for devices older than API 31
   See https://developer.android.com/about/versions/12/backup-restore
-->
<full-backup-content>
    <!-- API < 31 backup. Exclude the session secret stores so tokens/cookies never
         leave the device via auto-backup (the fallback file can be plaintext). -->
    <exclude domain="sharedpref" path="suvmusic_secure_session.xml"/>
    <exclude domain="sharedpref" path="suvmusic_secure_session_fallback.xml"/>
</full-backup-content>